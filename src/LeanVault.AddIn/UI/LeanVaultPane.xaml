<UserControl x:Class="LeanVault.AddIn.UI.LeanVaultPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI" FontSize="12"
             Background="#F5F5F5">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinWidth" Value="70"/>
        </Style>
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="6">

        <!-- Lock conflict banner -->
        <Border x:Name="ConflictBanner"
                DockPanel.Dock="Top"
                Background="#FFEEEE" BorderBrush="#CC0000" BorderThickness="1"
                Padding="6,4" Margin="0,0,0,6"
                Visibility="{Binding ConflictBannerVisibility}">
            <TextBlock Text="{Binding ConflictMessage}" Foreground="#CC0000"
                       FontWeight="Bold" TextWrapping="Wrap"/>
        </Border>

        <!-- Busy indicator -->
        <Border DockPanel.Dock="Top" Visibility="{Binding BusyVisibility}"
                Background="#E8F4FD" Padding="4,2" Margin="0,0,0,4">
            <TextBlock Text="{Binding BusyMessage}" Foreground="#0070C0"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Active file section -->
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Style="{StaticResource SectionHeader}" Text="Active File" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="⚙ Admin" Command="{Binding ShowAdminLocksCommand}" 
                            HorizontalAlignment="Right" Padding="4,0" Background="Transparent" BorderBrush="Transparent" Foreground="#888" FontSize="11"/>
                </DockPanel>
                <Border Background="White" BorderBrush="#DDD" BorderThickness="1" Padding="6" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="{Binding ActiveFileName}" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding ActiveFilePath}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Ellipse Style="{StaticResource StatusDot}" Fill="{Binding StatusColor}"/>
                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LockDetail}" Foreground="#666" FontSize="11"
                                   Margin="0,1,0,0" Visibility="{Binding LockDetailVisibility}"/>
                        <TextBlock Text="{Binding ChangesetText}" Foreground="#888" FontSize="10"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="Actions"/>
                <WrapPanel Margin="0,0,0,6">
                    <Button Style="{StaticResource ActionButton}"
                            Content="Check Out"
                            Command="{Binding CheckOutCommand}"
                            IsEnabled="{Binding CanCheckOut}"/>
                    <Button Style="{StaticResource ActionButton}"
                            Content="Check In"
                            Command="{Binding CheckInCommand}"
                            IsEnabled="{Binding CanCheckIn}"/>
                    <Button Style="{StaticResource ActionButton}"
                            Content="Undo"
                            Command="{Binding UndoCheckOutCommand}"
                            IsEnabled="{Binding CanUndo}"/>
                    <Button Style="{StaticResource ActionButton}"
                            Content="History"
                            Command="{Binding ShowHistoryCommand}"
                            IsEnabled="{Binding HasActiveFile}"/>
                </WrapPanel>

                <!-- Quick check-in prompt (shown after FileSave) -->
                <Border Visibility="{Binding QuickCheckInVisibility}"
                        Background="#FFFDE7" BorderBrush="#F9A825" BorderThickness="1"
                        Padding="6,4" Margin="0,0,0,6">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="File saved — check in now?"
                                   FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Button DockPanel.Dock="Right" Content="Check In" Padding="6,2"
                                Command="{Binding CheckInCommand}" Margin="4,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="Later" Padding="6,2"
                                Command="{Binding DismissQuickCheckInCommand}"/>
                    </DockPanel>
                </Border>

                <!-- Assembly lock conflict banner -->
                <Border Visibility="{Binding AssemblyLockBannerVisibility}"
                        Background="#FFF3CD" BorderBrush="#F0AD4E" BorderThickness="1"
                        Padding="6,4" Margin="0,0,0,4">
                    <TextBlock Text="{Binding AssemblyLockWarning}" Foreground="#856404"
                               TextWrapping="Wrap" FontSize="11"/>
                </Border>

                <!-- Assembly tree -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="Assembly Tree Status"
                           Visibility="{Binding AssemblyTreeVisibility}"/>
                <ItemsControl ItemsSource="{Binding AssemblyNodes}"
                              Visibility="{Binding AssemblyTreeVisibility}"
                              Margin="0,0,0,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <Ellipse Style="{StaticResource StatusDot}" Fill="{Binding StatusColor}"/>
                                <TextBlock Text="{Binding FileName}" FontSize="11"
                                           TextTrimming="CharacterEllipsis" MaxWidth="160"
                                           ToolTip="{Binding FilePath}"/>
                                <TextBlock Text="{Binding OwnerTag}" Foreground="#777"
                                           FontSize="10" Margin="4,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Assembly check-in button -->
                <Button Visibility="{Binding AssemblyTreeVisibility}"
                        Content="Check Out All"
                        Command="{Binding CheckOutAllCommand}"
                        Margin="0,0,0,4" Padding="8,4"
                        HorizontalAlignment="Stretch"/>
                <Button Visibility="{Binding AssemblyTreeVisibility}"
                        Content="Check In Assembly + All Parts"
                        Command="{Binding CheckInAssemblyCommand}"
                        Margin="0,0,0,4" Padding="8,4"
                        HorizontalAlignment="Stretch"/>

                <!-- History panel -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="History"
                           Visibility="{Binding HistoryVisibility}"/>
                <ItemsControl ItemsSource="{Binding HistoryEntries}"
                              Visibility="{Binding HistoryVisibility}"
                              Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="2,4">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Restore"
                                            Padding="4,1" FontSize="10"
                                            Command="{Binding DataContext.RestoreRevisionCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding Changeset}"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Changeset}" FontWeight="Bold" FontSize="11"/>
                                        <TextBlock Text="{Binding Author}" Foreground="#555" FontSize="10"/>
                                        <TextBlock Text="{Binding Comment}" TextWrapping="Wrap"
                                                   FontSize="10" Foreground="#333" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
