<UserControl x:Class="LeanVault.AddIn.UI.CheckInAssemblyDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="500" Height="400" FontFamily="Segoe UI" FontSize="12">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" Text="Check In Assembly" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
        
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Check In" Width="80" Margin="0,0,10,0" Click="CheckIn_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
        
        <TextBlock DockPanel.Dock="Bottom" Text="Comment:" FontWeight="SemiBold" Margin="0,10,0,5"/>
        <TextBox DockPanel.Dock="Bottom" x:Name="CommentTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <TextBlock DockPanel.Dock="Top" Text="Select files to check in:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ListView x:Name="FilesListView" BorderBrush="#CCC" BorderThickness="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,5,0"
                                  IsEnabled="{Binding CanSelect}"/>
                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</UserControl>
